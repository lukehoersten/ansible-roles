services:
  korsync:
    image: b1n4ryj4n/koreader-sync:arm
    container_name: korsync
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{korsync_port}}:8081"
    environment:
      - ENABLE_USER_REGISTRATION={{korsync_user_registration}}
    logging:
      driver: journald
    volumes:
      - {{korsync_dir}}/data/redis:/var/lib/redis
